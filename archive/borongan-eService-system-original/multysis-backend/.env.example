# Backend Environment Variables
NODE_ENV=development
PORT=3000
DEBUG_DB=false

# Local PostgreSQL Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=multysis
DB_USER=postgres
DB_PASSWORD=your_password
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/multysis

# Supabase Configuration (Alternative)
# For Supabase, set DATABASE_URL to the connection pooling string
# and DIRECT_URL to the direct connection string for migrations.
# DATABASE_URL=postgres://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgres://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key
JWT_REFRESH_SECRET=your-super-secret-refresh-key
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Email Configuration
EMAIL_ENABLED=true                    # Set to 'true' to enable email, 'false' to disable (default: checks if SMTP configured)
SMTP_HOST=smtp.gmail.com              # SMTP server hostname
SMTP_PORT=587                          # SMTP server port (default: 587, use 465 for SSL)
SMTP_SECURE=false                      # Use TLS/SSL (true for port 465, false for port 587)
SMTP_USER=your-email@gmail.com         # SMTP username/email
SMTP_PASS=your-app-password            # SMTP password or app-specific password
SMTP_FROM=noreply@multysis.local       # Default sender email address

# Cloud Storage (AWS S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=multysis-uploads

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# OAuth Configuration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/auth/facebook/callback

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# API Configuration
API_PREFIX=/api
API_VERSION=v1

# Logging
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# Session Configuration
SESSION_SECRET=your-session-secret
SESSION_MAX_AGE=86400000


# Twilio Configuration
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890  # Your Twilio phone number
OTP_EXPIRY_MINUTES=5             # OTP expiration time
OTP_LENGTH=6                      # OTP code length (default: 6)

# WebSocket Configuration
WS_PORT=3000  # Same as HTTP server
CORS_ORIGIN=http://localhost:5173
