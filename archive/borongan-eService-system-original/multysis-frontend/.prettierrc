{
  "semi": true,
  "trailingComma": "es5",
  "singleQuote": true,
  "printWidth": 120,
  "tabWidth": 2,
  "useTabs": false,
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "avoid",
  "endOfLine": "lf",
  "importOrder": [
    "^react$",
    "^react-dom$",
    "^react-router",
    "^@hookform",
    "^zod$",
    "^react-select$",
    "^@/components/ui",
    "^@/components",
    "^@/hooks",
    "^@/context",
    "^@/services",
    "^@/types",
    "^@/validations",
    "^@/utils",
    "^@/lib",
    "^[./]"
  ],
  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true
}
