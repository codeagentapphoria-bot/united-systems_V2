# ========================================
# BORONGAN UNIFIED DATABASE CONFIGURATION
# ========================================
# This .env file is for the UNIFIED DATABASE
# Replace [PASSWORD] and [KEY] with actual values from Supabase
# ========================================

# DATABASE CONNECTIONS - Unified Supabase
DATABASE_URL="postgresql://postgres.vcmerzrpegwfebgmhjwh:[PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.vcmerzrpegwfebgmhjwh:[PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres"

# SUPABASE API CREDENTIALS
SUPABASE_URL="https://vcmerzrpegwfebgmhjwh.supabase.co"
SUPABASE_ANON_KEY="[GET FROM SUPABASE DASHBOARD - Settings > API]"
SUPABASE_SERVICE_ROLE_KEY="[GET FROM SUPABASE DASHBOARD - Settings > API]"

# AUTHENTICATION
JWT_SECRET="[USE EXISTING OR GENERATE NEW]"
JWT_EXPIRY="7d"

# EMAIL SERVICE (existing)
EMAIL_HOST="[EXISTING VALUE]"
EMAIL_PORT="[EXISTING VALUE]"
EMAIL_USER="[EXISTING VALUE]"
EMAIL_PASSWORD="[EXISTING VALUE]"
EMAIL_FROM="[EXISTING VALUE]"

# APPLICATION
NODE_ENV="development"
PORT="5000"
APP_NAME="Borongan E-Services"
APP_VERSION="2.0.0"

# LOGGING
LOG_LEVEL="info"
LOG_FORMAT="json"

# CORS
CORS_ORIGIN="http://localhost:3000,https://your-frontend-domain.com"

# RATE LIMITING
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX_REQUESTS="100"

# SESSION CONFIG
SESSION_SECRET="[GENERATE NEW OR USE EXISTING]"
SESSION_EXPIRY="24h"

# SYNC & OFFLINE
SYNC_BATCH_SIZE="100"
SYNC_INTERVAL_MS="5000"
CONFLICT_RESOLUTION="manual"

# OPTIONAL: Advanced
DEBUG="false"
FEATURE_FLAGS="new_citizen_mapping:true,sync_queue:true"
