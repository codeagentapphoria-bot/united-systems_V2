# BIMS Client Environment Configuration
# Copy this file to .env for your environment

# =============================================================================
# API CONFIGURATION
# =============================================================================
# Development: http://localhost:5000
# Production: http://YOUR_IP_ADDRESS:5000 or http://your-domain.com
VITE_API_BASE_URL=http://13.211.71.85/api
VITE_SERVER_URL=http://13.211.71.85

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================
# For production deployments, update these URLs
VITE_PRODUCTION_API_URL=https://your-api-domain.com
VITE_STAGING_API_URL=https://staging-api.your-domain.com

# =============================================================================
# FEATURE FLAGS
# =============================================================================
VITE_ENABLE_DEBUG=false
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_LOGGING=true
VITE_ENABLE_DEBUG=true

# Enable error reporting (for production error tracking)
VITE_ENABLE_ERROR_REPORTING=false

# =============================================================================
# EXTERNAL API INTEGRATION
# =============================================================================
# Geoserver API Integration
VITE_EXTERNAL_API_URL=http://localhost
VITE_EXTERNAL_API_KEY=your_api_key_here
VITE_DEBUG_API=false

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
VITE_APP_NAME=BIMS
VITE_APP_VERSION=1.0.0
VITE_APP_ENVIRONMENT=development

# =============================================================================
# MAP CONFIGURATION
# =============================================================================
VITE_MAP_CENTER_LAT=11.6084
VITE_MAP_CENTER_LNG=125.4319
VITE_MAP_ZOOM=10
VITE_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# =============================================================================
# UPLOAD CONFIGURATION
# =============================================================================
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# =============================================================================
# PAGINATION CONFIGURATION
# =============================================================================
VITE_DEFAULT_PAGE_SIZE=10
VITE_MAX_PAGE_SIZE=100

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================
VITE_CACHE_ENABLED=true
VITE_CACHE_DURATION=300000

# =============================================================================
# NOTIFICATION CONFIGURATION
# =============================================================================
VITE_NOTIFICATION_DURATION=5000
VITE_ENABLE_PUSH_NOTIFICATIONS=false
