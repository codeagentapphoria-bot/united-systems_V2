# BIMS Frontend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
#
#   cp .env.example .env
#
# Only VITE_ variables actually READ by the frontend source code are listed here.
# =============================================================================

# =============================================================================
# BIMS BACKEND (required)
# =============================================================================

# Full API base URL of the BIMS backend (with /api suffix)
VITE_API_BASE_URL=https://bims-api.your-domain.com/api

# BIMS backend origin without the /api suffix — used to construct image/upload URLs.
# Must match VITE_API_BASE_URL but without the path.
VITE_SERVER_URL=https://bims-api.your-domain.com

# =============================================================================
# E-SERVICES PORTAL (optional)
# URL of the E-Services resident portal — shown on the retired public certificate
# request page (/request) as a redirect link. Leave empty to suppress the link.
# =============================================================================
VITE_ESERVICE_URL=https://portal.your-domain.com

# =============================================================================
# EXTERNAL OPEN API (optional)
# Used by the Open API integration feature in the BIMS admin panel.
# Leave VITE_EXTERNAL_API_URL blank to disable the feature.
# =============================================================================
VITE_EXTERNAL_API_URL=
VITE_EXTERNAL_API_KEY=

# =============================================================================
# SETUP EMAIL (optional)
# SMTP sender name forwarded to the backend when the barangay setup email
# feature is used. Leave blank to use the backend SMTP_FROM value.
# =============================================================================
VITE_SMTP_FROM=

# =============================================================================
# FEATURE FLAGS
# =============================================================================
VITE_ENABLE_DEBUG=false
VITE_ENABLE_ERROR_REPORTING=false
VITE_DEBUG_API=false
