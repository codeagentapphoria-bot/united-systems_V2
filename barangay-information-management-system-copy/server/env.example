# BIMS Server — Unified Supabase Database Configuration
# =============================================================================
# Copy this file to .env (or .env.production) when connecting to the
# Borongan Unified Supabase database instead of the original bims_production DB.
#
# HOW TO USE:
#   cp server/env.unified server/.env
#   # Then fill in the Supabase connection values below.
#
# IMPORTANT — Supabase connection modes:
#   - PG_HOST / PG_PORT / PG_SSL below use the DIRECT connection (for migrations).
#   - For the app (pooled), use the Supabase PgBouncer URL instead:
#       postgres://[user]:[password]@[project].pooler.supabase.com:6543/postgres
#     Set PG_PORT=6543 and PG_HOST to the pooler host if using PgBouncer.
# =============================================================================

# =============================================================================
# DATABASE — Supabase Unified DB
# Get these from: Supabase Dashboard → Project Settings → Database
# =============================================================================
PG_USER=postgres.exahyuahguriwrkkeuvm
PG_HOST=aws-1-ap-south-1.pooler.supabase.com
PG_DATABASE=postgres
PG_PASSWORD=rPb3&gYLXpr@gH?
PG_PORT=6543
PG_SSL=true

# For direct (non-pooled) connections e.g. migrations:
# PG_HOST=db.exahyuahguriwrkkeuvm.supabase.co
# PG_PORT=5432

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
JWT_SECRET=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiYWRtaW4iOnRydWUsImlhdCI6MTUxNjIzOTAyMn0.KMUFsIDTnFmyG3nMiGM6H9FNFUROf3wh7SmqJp-QV30
JWT_EXPIRES_IN=1d

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
PORT=5000
NODE_ENV=production
HOST=0.0.0.0
CLIENT_URL=http://localhost:3000

# =============================================================================
# DATABASE SETUP CONFIGURATION
# =============================================================================
SETUP_LOCK_ID=54321
DEFAULT_MUNICIPALITY_NAME="Default Municipality"
DEFAULT_DESCRIPTION="Write a description here"
DEFAULT_REGION="Default Region"
DEFAULT_PROVINCE="Default Province"
DEFAULT_ADMIN_EMAIL=administrator@borongan.gov.ph
DEFAULT_ADMIN_PASSWORD=Administrator-ocotober-2025
DEFAULT_ADMIN_NAME=Administrator

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
GMAIL_USER=rosettascript@gmail.com
GMAIL_PASS=sahb uawx mdxc dgic
SMTP_FROM=noreply@borongan.gov.ph

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/gif,application/pdf"

# =============================================================================
# OPEN API CONFIGURATION
# =============================================================================
OPENAPI_ENABLED=true
OPENAPI_DEFAULT_RATE_LIMIT_PER_MINUTE=60

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
CORS_ORIGIN=http://13.211.71.85
CORS_CREDENTIALS=true

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# =============================================================================
# DEPLOYMENT FLAGS
# =============================================================================
DB_SEEDED=true
GIS_DATA_IMPORTED=true

# =============================================================================
# REDIS CONFIGURATION (Optional)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis1234
REDIS_DB=0

# =============================================================================
# EXTERNAL API CONFIGURATION
# =============================================================================
EXTERNAL_API_URL=http://localhost
EXTERNAL_API_KEY=your_api_key_here
DEBUG_API=false
