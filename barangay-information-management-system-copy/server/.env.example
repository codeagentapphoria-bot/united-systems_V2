# BIMS Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the required values.
#
#   cp .env.example .env
#
# Only variables actually READ by server code are listed here.
# =============================================================================

# =============================================================================
# DATABASE (PostgreSQL — shared with E-Services backend)
# Both backends MUST point to the same database instance.
#
# Supabase (pooled — use for app queries):
#   PG_HOST=aws-X-ap-southeast-1.pooler.supabase.com   PG_PORT=6543   PG_SSL=true
# Supabase (direct — use for Prisma migrations, not needed on BIMS backend):
#   PG_HOST=db.your-project-ref.supabase.co            PG_PORT=5432   PG_SSL=true
# Self-hosted:
#   PG_HOST=localhost   PG_PORT=5432   PG_SSL=false
# =============================================================================
PG_USER=postgres
PG_HOST=localhost
PG_DATABASE=united_systems
PG_PASSWORD=your_database_password
PG_PORT=5432
PG_SSL=false

# =============================================================================
# JWT
# CRITICAL: JWT_SECRET must be IDENTICAL to the E-Services backend JWT_SECRET.
# Both backends validate each other's tokens — mismatched secrets cause 401 errors
# on all portal household requests.
#
# Generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# =============================================================================
JWT_SECRET=your-48-byte-hex-secret-here
JWT_EXPIRES_IN=1d

# =============================================================================
# SERVER
# =============================================================================
PORT=5000
NODE_ENV=production

# Public base URL of this BIMS backend — used in SQL queries to construct
# absolute image/upload URLs returned to the frontend.
BASE_URL=https://bims-api.your-domain.com

# =============================================================================
# CORS
# Comma-separate multiple allowed origins.
# Must include the BIMS frontend AND the E-Services portal (the portal calls
# BIMS directly for household data using credentials:include).
# =============================================================================
CORS_ORIGIN=https://bims.your-domain.com,https://portal.your-domain.com

# =============================================================================
# EMAIL (optional)
# Both GMAIL_USER and GMAIL_PASS must be set to enable outgoing email.
# Use a Gmail App Password (not your regular Gmail password):
#   Google Account → Security → 2-Step Verification → App passwords
# =============================================================================
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_PASS=your_gmail_app_password_here
SMTP_FROM=noreply@your-domain.gov.ph

# =============================================================================
# REDIS (optional)
# Set REDIS_ENABLED=false to run without Redis (disables caching and rate limiting).
# When disabled, all cache operations are instant no-ops — useful for dev without Redis installed.
# =============================================================================
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# PUPPETEER — PDF certificate generation
# Uncomment these on Linux servers without a display (Docker, CI, VPS).
# =============================================================================
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
# PUPPETEER_NO_SANDBOX=true

# =============================================================================
# INITIAL DATABASE SEEDING (src/scripts/seedDatabase.js only)
# These are used by the one-off seed script, not by the running Express server.
# Set them before running the seed script on a fresh database.
# =============================================================================
SETUP_LOCK_ID=54321
DEFAULT_MUNICIPALITY_NAME=Your Municipality
DEFAULT_REGION=Your Region
DEFAULT_PROVINCE=Your Province
DEFAULT_DESCRIPTION=Barangay Information Management System
DEFAULT_ADMIN_EMAIL=admin@your-domain.gov.ph
DEFAULT_ADMIN_PASSWORD=ChangeThisPassword123!
DEFAULT_ADMIN_NAME=System Administrator
