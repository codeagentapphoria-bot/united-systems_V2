# E-Services (Multysis) Frontend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
#
#   cp .env.example .env
#
# Only VITE_ variables actually READ by the frontend source code are listed here.
# =============================================================================

# =============================================================================
# E-SERVICES BACKEND (required)
# Full URL of the E-Services backend API, including the /api suffix.
# =============================================================================
VITE_API_BASE_URL=https://eservice-api.your-domain.com/api

# =============================================================================
# BIMS BACKEND (required)
# Full URL of the BIMS backend API, including the /api suffix.
# Used by the portal household page (PortalMyHousehold) to call the BIMS
# backend directly for household data.
# Note: BIMS backend CORS_ORIGIN must include this frontend's origin.
# =============================================================================
VITE_BIMS_API_BASE_URL=https://bims-api.your-domain.com/api

# =============================================================================
# PORTAL PUBLIC URL (required)
# This frontend's own public URL — embedded in QR codes on the resident ID card.
# Scanning the QR code opens this URL + the resident's registration status path.
# =============================================================================
VITE_PORTAL_URL=https://portal.your-domain.com

# =============================================================================
# SUPABASE (required for Google OAuth login)
# Get from: Supabase Dashboard → Project Settings → API
# The anon key is a public key — safe to embed in frontend code.
# =============================================================================
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_SUPABASE_TIMEOUT=120000

# =============================================================================
# MOCK API (optional)
# Enables mock API responses in development for testing without a live backend.
# Always set to false in production.
# =============================================================================
VITE_MOCK_API=false
