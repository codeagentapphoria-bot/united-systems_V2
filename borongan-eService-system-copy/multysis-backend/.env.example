# E-Services Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in all required values.
#
#   cp .env.example .env
#
# Only variables actually READ by server code are listed here.
# =============================================================================

# =============================================================================
# DATABASE (Prisma — shared with BIMS backend)
# Both backends MUST point to the same database instance.
#
# DATABASE_URL → pooled connection (PgBouncer) for runtime app queries
# DIRECT_URL   → direct connection for Prisma schema sync / migrations
#
# Supabase:
#   DATABASE_URL=postgres://user:pass@project.pooler.supabase.com:6543/postgres?pgbouncer=true
#   DIRECT_URL=postgres://user:pass@db.project-ref.supabase.co:5432/postgres
#
# Self-hosted:
#   DATABASE_URL=postgres://user:pass@localhost:5432/united_systems
#   DIRECT_URL=postgres://user:pass@localhost:5432/united_systems
# =============================================================================
DATABASE_URL=postgres://user:password@localhost:5432/united_systems
DIRECT_URL=postgres://user:password@localhost:5432/united_systems

# =============================================================================
# JWT
# CRITICAL: JWT_SECRET must be IDENTICAL to the BIMS backend JWT_SECRET.
# Both backends validate each other's tokens — mismatched secrets cause 401
# errors on all portal household requests.
#
# Generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# =============================================================================
JWT_SECRET=change-me-at-least-32-chars-and-match-bims

# =============================================================================
# SERVER
# =============================================================================
PORT=3000
NODE_ENV=production

# Public base URL of this backend — used for CSP headers and constructing
# file/upload URLs returned to the frontend.
API_BASE_URL=https://eservice-api.your-domain.com

# =============================================================================
# AUTH TOKENS & COOKIES
# These have sensible defaults — only override if you need non-standard values.
# =============================================================================
ACCESS_TOKEN_EXPIRES=10m
REFRESH_TOKEN_EXPIRES=30d
IDLE_TIMEOUT=15m
ABSOLUTE_TIMEOUT=6h

# Cookie attributes — auto-derived from NODE_ENV, but set explicitly in production.
COOKIE_SECURE=true
COOKIE_SAME_SITE=strict
# COOKIE_DOMAIN=.your-domain.com    # set to your root domain to share cookies across subdomains
COOKIE_PATH=/

# =============================================================================
# CORS
# Allow the E-Services portal frontend.
# Comma-separate to allow multiple origins.
# =============================================================================
CORS_ORIGIN=https://portal.your-domain.com

# Portal public URL — embedded in registration approval email login links
# and used as base for Google OAuth redirects.
PORTAL_URL=https://portal.your-domain.com

# =============================================================================
# EMAIL (optional)
# All three of SMTP_HOST, SMTP_USER, and SMTP_PASS must be set to enable email.
# Using Gmail: create an App Password at Google Account → Security → App passwords.
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_gmail_app_password_here
SMTP_FROM=noreply@your-domain.gov.ph

# =============================================================================
# GOOGLE OAUTH (optional)
# Leave all three blank to disable Google login.
# Create credentials at: console.cloud.google.com → APIs & Services → Credentials
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://eservice-api.your-domain.com/api/auth/portal/google/callback

# =============================================================================
# SUPABASE (required only if using Supabase Auth for Google OAuth)
# Get from: Supabase Dashboard → Project Settings → API
# SERVICE_ROLE_KEY is secret — never expose it in the frontend.
# =============================================================================
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# =============================================================================
# TWILIO / OTP SMS (optional)
# Leave all three blank to disable OTP SMS sending.
# =============================================================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# =============================================================================
# DEVELOPER LOGIN (development only — leave blank in production)
# Provides a pre-configured portal login for development testing.
# DEV_PASSWORD must be a bcrypt-hashed password string.
#   Generate: node -e "require('bcrypt').hash('yourpassword',12).then(console.log)"
# =============================================================================
DEV_EMAIL=
DEV_PASSWORD=

# =============================================================================
# DATABASE DEBUG
# Enables verbose Prisma query logging when NODE_ENV=development.
# =============================================================================
DEBUG_DB=false
