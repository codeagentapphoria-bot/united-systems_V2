# E-Services (Multysis) Backend — Unified Supabase Database Configuration
# =============================================================================
# Copy this file to .env when connecting to the Borongan Unified Supabase
# database instead of the original multysis DB.
#
# HOW TO USE:
#   cp .env.unified .env
#   # Then fill in the Supabase connection values below.
#
# PRISMA NOTE:
#   The User model @@map has been updated from "users" → "eservice_users".
#   After updating .env, run:
#     npx prisma migrate deploy    ← for production (applies pending migrations)
#     npx prisma db push           ← for initial sync against unified schema
#     npx prisma generate          ← regenerates the Prisma client
#
# SUPABASE CONNECTION MODES:
#   DATABASE_URL  → PgBouncer (pooled) — use for all app queries (port 6543)
#   DIRECT_URL    → Direct connection  — use for Prisma migrations (port 5432)
#   Both URLs are required when using Supabase with Prisma.
# =============================================================================

NODE_ENV=production
PORT=3000
DEBUG_DB=false

# =============================================================================
# DATABASE — Supabase Unified DB
# Get these from: Supabase Dashboard → Project Settings → Database
# =============================================================================

# Pooled connection (PgBouncer) — for runtime app queries
DATABASE_URL=postgres://postgres.exahyuahguriwrkkeuvm:rPb3%26gYLXpr%40gH%3F@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct connection — for Prisma migrate / db push
DIRECT_URL=postgres://postgres.exahyuahguriwrkkeuvm:rPb3%26gYLXpr%40gH%3F@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
JWT_SECRET=your-super-secret-jwt-key
JWT_REFRESH_SECRET=your-super-secret-refresh-key
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@borongan.gov.ph

# =============================================================================
# CLOUD STORAGE (AWS S3)
# =============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=multysis-uploads

# =============================================================================
# FRONTEND / CORS
# =============================================================================
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# =============================================================================
# OAUTH CONFIGURATION
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/auth/facebook/callback

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# FILE UPLOAD
# =============================================================================
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# =============================================================================
# API CONFIGURATION
# =============================================================================
API_PREFIX=/api
API_VERSION=v1

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# =============================================================================
# SESSION
# =============================================================================
SESSION_SECRET=your-session-secret
SESSION_MAX_AGE=86400000

# =============================================================================
# TWILIO / OTP
# =============================================================================
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890
OTP_EXPIRY_MINUTES=5
OTP_LENGTH=6

# =============================================================================
# WEBSOCKET
# =============================================================================
WS_PORT=3000
