// =============================================================================
// CERTIFICATE TEMPLATES (AC4)
// HTML templates with {{ placeholder }} tokens, scoped per municipality + type.
// =============================================================================

model CertificateTemplate {
  id              String   @id @default(uuid())
  municipalityId  Int      @map("municipality_id")
  certificateType String   @map("certificate_type")  // e.g. 'barangay_clearance', 'indigency'
  name            String
  description     String?
  htmlContent     String   @map("html_content")       // HTML with {{ placeholder }} tokens
  isActive        Boolean  @map("is_active") @default(true)
  createdBy       String?  @map("created_by")         // bims_users.id
  createdAt       DateTime @map("created_at") @default(now())
  updatedAt       DateTime @map("updated_at") @updatedAt

  municipality Municipality @relation(fields: [municipalityId], references: [id], onDelete: Cascade)

  @@unique([municipalityId, certificateType])
  @@index([municipalityId])
  @@index([certificateType])
  @@map("certificate_templates")
}
